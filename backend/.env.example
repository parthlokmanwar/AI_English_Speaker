# FluentRound — Environment Variables
# Copy this file to .env and fill in your API key

# Get your free OpenRouter API key at https://openrouter.ai
# Go to API Keys section → Create a new key → Paste below
OPENROUTER_API_KEY=your_openrouter_api_key_here
FREE_MODELS=meta-llama/llama-3.3-70b-instruct:free,qwen/qwen-3-235b-a22b:free,deepseek/deepseek-chat-v3-0324:free
PAID_FALLBACK_MODEL=openai/gpt-4o-mini
